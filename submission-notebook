    "def inference(model, cond, test_loader, test_data, device):\n",
    "    \n",
    "    levels = [\"l1_l2\", \"l2_l3\", \"l3_l4\", \"l4_l5\", \"l5_s1\"]\n",
    "    \n",
    "\n",
    "    num_correct = 0\n",
    "    if cond==\"spinal-canal-stenosis\":\n",
    "        model.eval()\n",
    "        y_pred = {\"l1_l2\": [], \"l2_l3\": [], \"l3_l4\": [], \"l4_l5\": [], \"l5_s1\": []}\n",
    "    else:\n",
    "        model[0].eval()\n",
    "        model[1].eval()\n",
    "        y_pred_left = {\"l1_l2\": [], \"l2_l3\": [], \"l3_l4\": [], \"l4_l5\": [], \"l5_s1\": []}\n",
    "        y_pred_right = {\"l1_l2\": [], \"l2_l3\": [], \"l3_l4\": [], \"l4_l5\": [], \"l5_s1\": []}\n",
    "        \n",
    "    C=5\n",
    "\n",
    "    for batch_data in tqdm(test_loader):\n",
    "        if cond==\"spinal-canal-stenosis\":\n",
    "            patches, study_id = batch_data\n",
    "\n",
    "            with torch.no_grad():\n",
    "                loss = 0\n",
    "                for i in range(C):    \n",
    "                    # outputs, _ = model(patches[levels[i]].to(device))\n",
    "                    outputs = model(patches[levels[i]].to(device))\n",
    "                    y_pred[levels[i]].append((study_id[0], \n",
    "                                              list(outputs.softmax(dim=-1)[0].cpu().numpy())))\n",
    "\n",
    "        else:\n",
    "            patches_left, patches_right, study_id = batch_data\n",
    "\n",
    "            with torch.no_grad():\n",
    "                loss = 0\n",
    "                for i in range(C):    \n",
    "                    # outputs, _ = model(patches[levels[i]].to(device))\n",
    "                    outputs = model[0](patches_left[levels[i]].to(device))\n",
    "                    y_pred_left[levels[i]].append((study_id[0], \n",
    "                                              list(outputs.softmax(dim=-1)[0].cpu().numpy())))\n",
    "                    outputs = model[1](patches_right[levels[i]].to(device))\n",
    "                    y_pred_right[levels[i]].append((study_id[0], \n",
    "                                              list(outputs.softmax(dim=-1)[0].cpu().numpy())))\n",
    "                 \n",
    "    if cond==\"spinal-canal-stenosis\":\n",
    "        return y_pred\n",
    "    else:\n",
    "        return y_pred_left, y_pred_right"
