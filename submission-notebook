\"{subject_id}-{series_uid}\")\n    \n    if not os.path.exists(output_file):\n        os.makedirs(output_file)\n\n    dcm2niix_command = f\"dcm2niix -z y -m 2 -o {output_file} {input_file}\"\n    print(f\"Running command: {dcm2niix_command}\")\n\n    try:\n        subprocess.run(dcm2niix_command, shell=True, check=True)\n        print(f\"DICOM to NIfTI conversion completed successfully for subject {subject_id}, series {series_uid}.\")\n    except subprocess.CalledProcessError as e:\n        print(f\"Error executing dcm2niix command for subject {subject_id}, series {series_uid}: {e}\")","metadata":{"execution":{"iopub.status.busy":"2024-09-26T01:40:07.054466Z","iopub.execute_input":"2024-09-26T01:40:07.054853Z","iopub.status.idle":"2024-09-26T01:40:07.062672Z","shell.execute_reply.started":"2024-09-26T01:40:07.054799Z","shell.execute_reply":"2024-09-26T01:40:07.061700Z"},"trusted":true},"execution_count":13,"outputs":[]},{"cell_type":"code","source":"def merge_nifti_volumes(output_filename, output_path, subject_id, series_uid):\n    \"\"\"\n    Merge NIfTI volumes in the Z direction and save the merged volume if more than one volume exists.\n    Otherwise, save the single volume directly.\n    Rename the merged volume to the specified format.\n    \n    Parameters:\n    output_filename (str): Output filename for the merged NIfTI volume.\n    output_path (str): Path to the output directory for merged NIfTI volume.\n    subject_id (str): The subject identifier.\n    series_uid (str): The series instance UID.\n    \"\"\"\n    output_path_for_merge = os.path.join(output_path, f\"{subject_id}-{series_uid}\")\n\n    filenames = glob.glob(os.path.join(output_path_for_merge, '*.nii.gz'))\n    filenames.sort()\n\n    if len(filenames) > 1:\n        volumes = [nib.load(filename) for filename in filenames]\n        arrays = [vol.get_fdata() for vol in volumes]\n        affines = [vol.affine for vol in volumes]\n\n        merged_data = np.concatenate(arrays[::-1], axis=-1)\n        merged_nifti = nib.Nifti1Image(merged_data, affines[0])\n        merged_filename = f\"sub-{subject_id}_run-{series_uid}.nii.gz\"\n        merged_path = os.path.join(output_path, merged_filename)\n        nib.save(merged_nifti, merged_path)\n        print(f\"Merged volume saved as {merged_path}\")\n    elif len(filenames) == 1:\n        merged_filename = f\"sub-{subject_id}_run-{series_uid}.nii.gz\"\n        merged_path = os.path.join(output_path, merged_filename)\n        os.rename(filenames[0], merged_path)\n        print(f\"Single volume saved as {merged_path}\")\n    else:\n        print(f\"No NIfTI volumes found in {output_path}. Nothing saved.\")","metadata":{"execution":{"iopub.status.busy":"2024-09-26T01:40:08.914104Z","iopub.execute_input":"2024-09-26T01:40:08.914518Z","iopub.status.idle":"2024-09-26T01:40:08.924665Z","shell.execute_reply.started":"2024-09-26T01:40:08.914468Z","shell.execute_reply":"2024-09-26T01:40:08.923365Z"},"trusted":true},"execution_count":14,"outputs":[]},{"cell_type":"code","source":"def process_subject(subject_id, input_path, output_path, train, meta_obj):\n    \"\"\"\n    Process DICOM to NIfTI conversion, merge volumes, and save with corrected orientation if applicable.\n    \n    Parameters:\n    subject_id (str): The subject identifier.\n    input_path (str): Path to the DICOM images directory.\n    output_path (str): Path to the output directory for NIfTI files.\n    train (DataFrame): DataFrame containing series information.\n    meta_obj (dict): Metadata object with series information.\n    \"\"\"\n\n    if subject_id not in train['study_id'].astype(str).values:\n        print(f\"Subject ID {subject_id} not found in the train DataFrame.\")\n        return\n\n    filtered_series = train[train['study_id'] == int(subject_id)].iloc[0]\n    ptobj = meta_obj[str(filtered_series['study_id'])]\n\n    if ptobj is None:\n        print(f\"Metadata for Subject ID {subject_id} not found in meta_obj.\")\n        return\n\n    for idx, series_uid in enumerate(ptobj['SeriesInstanceUIDs']):\n        description = ptobj['SeriesDescriptions'][idx]\n\n        if \"Sagittal\" in description:\n            \n            print(f\"Processing series {series_uid} for subject {subject_id}...\")\n            convert_dicom_to_nifti(subject_id, series_uid, input_path, output_path)\n            merge_nifti_volumes(output_path, output_path, subject_id, series_uid)\n\n            if 'Axial' in description and 'T2' in description:\n                modality = 'T2w'\n                acq = 'ax'\n            elif 'Sagittal' in description and 'T1' in description:\n                modality = 'T1w'\n                acq = 'sag'\n            elif 'Sagittal' in description and 'T2' in description:\n                modality = 'T2w'\n                acq = 'sag'\n            else:\n                continue\n\n            corrected_nifti_path = f\"bids-rsna-lscd/sub-{subject_id}/anat/sub-{subject_id}_acq-{acq}_rec{series_uid}_{modality}.nii.gz\"\n            merged_nifti_path = os.path.join(output_path, f\"sub-{subject_id}_run-{series_uid}.nii.gz\")\n\n            anat_img = nib.load(merged_nifti_path)\n            anat_data = anat_img.get_fdata()\n            anat_affine = anat_img.affine\n            anat_header = anat_img.header\n\n            new_affine = np.copy(anat_affine)\n            anat_header.set_qform(new_affine, code=1)\n            anat_header.set_sform(new_affine, code=1)\n\n            nib.save(nib.Nifti1Image(anat_data, new_affine, header=anat_header), corrected_nifti_path)\n            print(f\"Image saved: {corrected_nifti_path}\")","metadata":{"execution":{"iopub.status.busy":"2024-09-26T01:40:10.047764Z","iopub.execute_input":"2024-09-26T01:40:10.048467Z","iopub.status.idle":"2024-09-26T01:40:10.060395Z","shell.execute_reply.started":"2024-09-26T01:40:10.048428Z","shell.execute_reply":"2024-09-26T01:40:10.059434Z"},"trusted":true},"execution_count":15,"outputs":[]},{"cell_type":"code","source":"def make_dir